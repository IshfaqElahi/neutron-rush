datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String       @id @default(uuid())
  name            String
  email           String?      @unique
  school          String?
  teamName        String?
  phone           String?
  playerId        String       @unique
  role            String       @default("PLAYER") // "PLAYER" | "ADMIN"
  createdAt       DateTime     @default(now())
  
  responses       Response[]
  leaderboardRank Leaderboard?

  @@index([playerId])
}

model Question {
  id            String     @id @default(uuid())
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correct       String     // "A" | "B" | "C" | "D"
  marks         Int        @default(10)
  negativeMarks Int        @default(0)
  category      String     @default("General")
  difficulty    String     @default("Medium") // "Easy" | "Medium" | "Hard"
  used          Boolean    @default(false)    // Tracks if used in the current run
  
  responses     Response[]
}

model QuizState {
  id                String     @id @default("ACTIVE_QUIZ")
  title             String     @default("Neutron Rush Championship")
  status            String     @default("DRAFT")  // "DRAFT" | "WAITING_ROOM" | "COUNTDOWN" | "QUESTION" | "REVEAL_ANSWER" | "ENDED"
  timerSeconds      Int        @default(15)
  showSchool        Boolean    @default(true)
  showTeamName      Boolean    @default(true)
  currentQuestionId String?
  registrationLocked Boolean   @default(false)
  updatedAt         DateTime   @updatedAt
}

model Response {
  id             String   @id @default(uuid())
  userId         String
  questionId     String
  selectedAnswer String?  // Null on timeout
  isCorrect      Boolean  @default(false)
  timeTakenMs    Int      @default(0)
  scoreEarned    Int      @default(0)
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

model Leaderboard {
  id             String   @id @default(uuid())
  userId         String   @unique
  score          Int      @default(0)
  accuracy       Float    @default(0.0)
  totalTimeMs    Int      @default(0)
  previousRank   Int      @default(0)  // Used to calculate visual up/down indicators
  currentRank    Int      @default(0)
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}